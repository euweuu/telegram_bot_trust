# Required
BOT_TOKEN=your_telegram_bot_token_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Webhook (production on Render)
# Set this to your Render service URL, e.g. https://your-service.onrender.com
# Leave unset for local development (falls back to polling)
WEBHOOK_URL=https://your-service.onrender.com

# Optional: adds a secret token check to webhook requests for extra security
# WEBHOOK_SECRET=some_random_secret

# Dispatcher Telegram IDs (comma-separated)
# These users get access to dispatcher menu: all-drivers stats + broadcast
# To find your Telegram ID, message @userinfobot
# DISPATCHER_IDS=123456789,987654321